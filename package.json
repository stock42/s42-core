{
	"name": "s42-core",
	"version": "3.0.5",
	"description": "S42-Core v3 is a Bun-first, 100% module-oriented backend framework where each module encapsulates everything needed to work autonomously in production systems.",
	"keywords": [
		"bun",
		"bunjs",
		"backend",
		"framework",
		"typescript",
		"modules",
		"microservices",
		"events",
		"redis",
		"mongodb",
		"sqlite",
		"sql",
		"sse",
		"cluster",
		"ai",
		"stock42"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"type": "module",
	"module": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"src",
		"DOCUMENTATION",
		"README.md",
		"README.es.md",
		"CHANGELOG.md",
		"ROADMAP.md",
		"LICENSE"
	],
	"scripts": {
		"typecheck": "bunx tsc --noEmit",
		"typecheck:modules": "bunx tsc -p tsconfig.modules.json --noEmit",
		"lint": "bunx eslint \"src/**/*.ts\"",
		"test": "bun test",
		"prepublishOnly": "bun run typecheck"
	},
	"engines": {
		"bun": ">=1.3.0"
	},
	"packageManager": "bun@1.3.6",
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"bugs": {
		"url": "https://github.com/stock42/s42-core/issues"
	},
	"homepage": "https://s42core.com",
	"author": {
		"name": "César Casas",
		"url": "https://www.linkedin.com/in/cesarcasas/"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/stock42/s42-core"
	},
	"license": "MIT",
	"dependencies": {
		"@aws-sdk/client-sqs": "^3.1000.0",
		"jsonwebtoken": "^9.0.3",
		"mongodb": "^6.21.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"@types/node": "^22.19.13",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"autoprefixer": "^10.4.27",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3"
	}
}
